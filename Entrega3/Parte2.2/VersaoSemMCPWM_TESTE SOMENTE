/*
  TESTE DE DIAGNÓSTICO - sem MCPWM, só para confirmar que o motor,
  o driver A4988 e a fiação estão corretos.
 só colar no lugar do .ino
  Gera o pulso de STEP manualmente com digitalWrite + delayMicroseconds.
 
 */

const int PIN_STEP = 27;
const int PIN_DIR  = 14;

void setup() {
  Serial.begin(115200);
  pinMode(PIN_STEP, OUTPUT);
  pinMode(PIN_DIR, OUTPUT);
  digitalWrite(PIN_DIR, HIGH);
  Serial.println("Teste de diagnostico: girando o motor manualmente...");
}

void loop() {
  // 200 passos = 1 volta completa, a ~5ms por passo (~1s por volta)
  for (int i = 0; i < 200; i++) {
    digitalWrite(PIN_STEP, HIGH);
    delayMicroseconds(500);
    digitalWrite(PIN_STEP, LOW);
    delayMicroseconds(4500);
  }
  Serial.println("Uma volta completa!");
  delay(500);
}
